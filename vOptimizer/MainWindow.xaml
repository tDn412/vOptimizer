<ui:FluentWindow x:Class="vOptimizer.MainWindow"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
              xmlns:views="clr-namespace:vOptimizer.Views"
              mc:Ignorable="d"
              Title="vOptimizer - Windows System Optimizer" Height="650" Width="1000"
              WindowStartupLocation="CenterScreen"
              ExtendsContentIntoTitleBar="True"
              WindowBackdropType="Mica"
              Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Windows 11 TitleBar without shadows -->
        <ui:TitleBar Grid.Row="0"
                      Title="vOptimizer - Smart Auto-Tuner &amp; Latency Tweaker"
                      Icon="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />

        <!-- Main Layout with NavigationView (transparent backdrop for seamless blending) -->
        <ui:NavigationView Grid.Row="1"
                             x:Name="NavView"
                             PaneDisplayMode="Left"
                             Background="Transparent">
            
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" Icon="Home24" TargetPageType="{x:Type views:DashboardPage}" />
                <ui:NavigationViewItem Content="Hardware Tuning" Icon="DeveloperBoard24" TargetPageType="{x:Type views:HardwarePage}" />
                <ui:NavigationViewItem Content="Optimize &amp; Benchmark" Icon="PlayRate24" TargetPageType="{x:Type views:BenchmarkPage}" />
                <ui:NavigationViewItem Content="Settings" Icon="Settings24" TargetPageType="{x:Type views:SettingsPage}" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
