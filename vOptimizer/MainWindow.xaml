<ui:UiWindow x:Class="vOptimizer.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             Title="vOptimizer - Windows System Optimizer" Height="680" Width="1020"
             WindowStartupLocation="CenterScreen"
             ExtendsContentIntoTitleBar="True"
             WindowBackdropType="Mica"
             Theme="Dark">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Windows 11 Style TitleBar -->
        <ui:TitleBar Grid.Row="0"
                     Title="vOptimizer - Smart Auto-Tuner &amp; Latency Tweaker"
                     Icon="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />

        <!-- Main Layout with NavigationView -->
        <ui:NavigationView Grid.Row="1"
                           PaneDisplayMode="LeftCompact"
                           IsSettingsVisible="False">
            
            <ui:NavigationView.MenuItems>
                <!-- Dashboard Panel -->
                <ui:NavigationViewItem Content="Dashboard" Icon="Home24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <ui:TextBlock Text="System Dashboard" FontScale="Subtitle" Margin="0,0,0,20"/>
                                
                                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                    <!-- CPU Status Card -->
                                    <ui:Card Width="300" Margin="0,0,15,15" Padding="15">
                                        <StackPanel>
                                            <ui:TextBlock Text="Processor Status" FontScale="Body" Foreground="Gray"/>
                                            <ui:TextBlock Text="{Binding CpuTempText, FallbackValue='Nhiệt độ: -- °C'}" FontScale="Title" Margin="0,10,0,5" />
                                            <ui:TextBlock Text="{Binding CpuPowerText, FallbackValue='Công suất: -- W'}" FontScale="Body" />
                                        </StackPanel>
                                    </ui:Card>

                                    <!-- Active Game Card -->
                                    <ui:Card Width="300" Margin="0,0,15,15" Padding="15">
                                        <StackPanel>
                                            <ui:TextBlock Text="Active Optimizer Context" FontScale="Body" Foreground="Gray"/>
                                            <ui:TextBlock Text="{Binding ActiveGameMode, FallbackValue='Chế độ: Balanced'}" FontScale="Title" Margin="0,10,0,5" Foreground="#FF0078D4" />
                                            <ui:TextBlock Text="{Binding ActiveProcessText, FallbackValue='Không phát hiện game đang chạy'}" FontScale="Body" />
                                        </StackPanel>
                                    </ui:Card>

                                    <!-- Tweak Status Card -->
                                    <ui:Card Width="300" Margin="0,0,15,15" Padding="15">
                                        <StackPanel>
                                            <ui:TextBlock Text="Tweak Status" FontScale="Body" Foreground="Gray"/>
                                            <ui:TextBlock Text="{Binding TweakStatusText, FallbackValue='OS Tweaks: Tắt'}" FontScale="Title" Margin="0,10,0,5" />
                                            <ui:TextBlock Text="{Binding RamStatusText, FallbackValue='RAM Standby: Sẵn sàng dọn'}" FontScale="Body" />
                                        </StackPanel>
                                    </ui:Card>
                                </WrapPanel>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>

                <!-- Hardware Tuning Panel -->
                <ui:NavigationViewItem Content="Hardware Tuning" Icon="DeveloperBoard24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <ui:TextBlock Text="Manual Hardware Tuning" FontScale="Subtitle" Margin="0,0,0,20"/>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                                        <!-- Intel FIVR Panel -->
                                        <ui:CardExpander Header="Intel FIVR Undervolting" IsExpanded="True" Margin="0,0,0,15">
                                            <StackPanel Margin="10">
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Text="CPU Core Offset (mV):" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-250" Maximum="0" Value="{Binding IntelCoreOffset, Mode=TwoWay}" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="1"/>
                                                    <ui:TextBlock Text="{Binding IntelCoreOffset, StringFormat={}{0} mV}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Text="CPU Cache Offset (mV):" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-250" Maximum="0" Value="{Binding IntelCacheOffset, Mode=TwoWay}" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="1"/>
                                                    <ui:TextBlock Text="{Binding IntelCacheOffset, StringFormat={}{0} mV}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </ui:CardExpander>

                                        <!-- AMD Tuning Panel -->
                                        <ui:CardExpander Header="AMD Curve Optimizer &amp; TDP" IsExpanded="True" Margin="0,0,0,15">
                                            <StackPanel Margin="10">
                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Text="Curve Optimizer Offset:" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-50" Maximum="0" Value="{Binding AmdCoOffset, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Grid.Column="1"/>
                                                    <ui:TextBlock Text="{Binding AmdCoOffset}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Text="Target TDP Limit (W):" VerticalAlignment="Center"/>
                                                    <ui:TextBox Text="{Binding AmdTdpText, Mode=TwoWay}" Grid.Column="1" TextAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </ui:CardExpander>

                                        <ui:Button Content="Apply Tuning Configuration" Command="{Binding ApplyHardwareCommand}" Appearance="Primary" Width="250" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>

                <!-- Benchmark & Compare Panel -->
                <ui:NavigationViewItem Content="Optimize &amp; Benchmark" Icon="PlayRate24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <ui:TextBlock Text="Performance Benchmark &amp; Comparison" FontScale="Subtitle" Margin="0,0,0,20"/>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Controls -->
                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <ui:Card Padding="15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <ui:TextBlock Text="Auto Benchmarking" FontScale="Body" Foreground="Gray"/>
                                                <ui:TextBlock Text="Chương trình sẽ chạy benchmark đo lường hiệu năng gốc (Stock), tự động áp dụng các tối ưu hóa undervolt và TDP, sau đó đo lường hiệu năng sau tối ưu (Optimized) để so sánh chi tiết." TextWrapping="Wrap" Margin="0,10,0,15" />
                                                
                                                <ui:Button Content="Start Auto-Optimize &amp; Benchmark" Command="{Binding RunAutoOptBenchmarkCommand}" Appearance="Primary" Height="40" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </ui:Card>

                                        <!-- Progress -->
                                        <ui:Card Padding="15" Visibility="{Binding ProgressCardVisibility, FallbackValue=Collapsed}">
                                            <StackPanel>
                                                <ui:ProgressRing IsIndeterminate="True" Height="60" Width="60" Margin="0,0,0,15"/>
                                                <ui:TextBlock Text="{Binding BenchmarkStatusText}" TextAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </ui:Card>
                                    </StackPanel>
                                    
                                    <!-- Results Side-by-Side Dashboard -->
                                    <ui:Card Grid.Column="1" Padding="20">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <ui:TextBlock Text="Tối Ưu Hóa &amp; So Sánh Kết Quả" FontScale="Body" FontWeight="Bold" Margin="0,0,0,15"/>
                                            
                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Headers -->
                                                <ui:TextBlock Text="Thông số đo lường" FontScale="Body" Foreground="Gray" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10"/>
                                                <ui:TextBlock Text="Chưa tối ưu (Stock)" FontScale="Body" Foreground="Gray" FontWeight="SemiBold" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" TextAlignment="Center"/>
                                                <ui:TextBlock Text="Đã tối ưu (vOptimizer)" FontScale="Body" Foreground="Gray" FontWeight="SemiBold" Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" TextAlignment="Center"/>
                                                <ui:TextBlock Text="Tỉ lệ cải thiện" FontScale="Body" Foreground="Gray" FontWeight="SemiBold" Grid.Row="0" Grid.Column="3" Margin="0,0,0,10" TextAlignment="Center"/>

                                                <Separator Grid.Row="0" Grid.ColumnSpan="4" VerticalAlignment="Bottom"/>

                                                <!-- Score -->
                                                <ui:TextBlock Text="Compute Score (GOPs):" Grid.Row="1" Grid.Column="0" Margin="0,15,0,15" VerticalAlignment="Center"/>
                                                <ui:TextBlock Text="{Binding StockScoreText}" Grid.Row="1" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding OptScoreText}" Grid.Row="1" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding DiffScoreText}" Grid.Row="1" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Green" FontScale="Body"/>
                                                
                                                <!-- Peak Temp -->
                                                <ui:TextBlock Text="Nhiệt độ cao nhất (°C):" Grid.Row="2" Grid.Column="0" Margin="0,15,0,15" VerticalAlignment="Center"/>
                                                <ui:TextBlock Text="{Binding StockTempText}" Grid.Row="2" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding OptTempText}" Grid.Row="2" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding DiffTempText}" Grid.Row="2" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Green" FontScale="Body"/>

                                                <!-- Avg Power -->
                                                <ui:TextBlock Text="Điện năng tiêu thụ (W):" Grid.Row="3" Grid.Column="0" Margin="0,15,0,15" VerticalAlignment="Center"/>
                                                <ui:TextBlock Text="{Binding StockPowerText}" Grid.Row="3" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding OptPowerText}" Grid.Row="3" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding DiffPowerText}" Grid.Row="3" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontScale="Body"/>

                                                <!-- Efficiency -->
                                                <ui:TextBlock Text="Hiệu suất (GOPs/Watt):" Grid.Row="4" Grid.Column="0" Margin="0,15,0,15" VerticalAlignment="Center"/>
                                                <ui:TextBlock Text="{Binding StockEfficiencyText}" Grid.Row="4" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding OptEfficiencyText}" Grid.Row="4" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontScale="Body"/>
                                                <ui:TextBlock Text="{Binding DiffEfficiencyText}" Grid.Row="4" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Green" FontScale="Body"/>
                                            </Grid>
                                        </Grid>
                                    </ui:Card>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:Frame x:Name="RootFrame" />

        </ui:NavigationView>
    </Grid>
</ui:UiWindow>
