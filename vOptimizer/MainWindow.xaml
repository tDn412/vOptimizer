<ui:UiWindow x:Class="vOptimizer.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             Title="vOptimizer - Windows System Optimizer" Height="650" Width="1000"
             WindowStartupLocation="CenterScreen"
             ExtendsContentIntoTitleBar="True"
             WindowBackdropType="Mica"
             Background="Transparent"
             Theme="Dark">
    
    <Window.Resources>
        <!-- Flat Button Style -->
        <Style TargetType="Button" x:Key="FlatButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Accent Button Style (Cyan / Mint Green) -->
        <Style TargetType="Button" x:Key="FlatAccentButton">
            <Setter Property="Background" Value="#00F5A0"/>
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FocusVisualStyle" Value="{Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00D48B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00B375"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Progress Bar Style -->
        <Style TargetType="ProgressBar" x:Key="FlatProgressBar">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#00F5A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0"/>
                            <Border Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" BorderThickness="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Windows 11 TitleBar without shadows -->
        <ui:TitleBar Grid.Row="0"
                      Title="vOptimizer - Smart Auto-Tuner &amp; Latency Tweaker"
                      Icon="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />

        <!-- Main Layout with NavigationView (transparent backdrop for seamless blending) -->
        <ui:NavigationView Grid.Row="1"
                            PaneDisplayMode="LeftCompact"
                            IsSettingsVisible="False"
                            PaneBackground="Transparent"
                            Background="Transparent">
            
            <ui:NavigationView.MenuItems>
                
                <!-- 1. SYSTEM DASHBOARD (Flat 4-Quadrant Grid) -->
                <ui:NavigationViewItem Content="Dashboard" Icon="Home24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Top-Left: SYSTEM STATUS -->
                                <Border Grid.Row="0" Grid.Column="0" BorderBrush="#2D2D2D" BorderThickness="0,0,1,1" Padding="30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="SYSTEM STATUS" FontFamily="Segoe UI Variable Text" FontSize="11" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>
                                        
                                        <!-- Temperature -->
                                        <Grid Grid.Row="1" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Processor Temperature (CPU Temp)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray"/>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBlock Text="{Binding CpuTempNum}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00F5A0"/>
                                                <TextBlock Text=" °C" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="Gray"/>
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar Grid.Row="2" Value="{Binding CpuTempNum}" Minimum="0" Maximum="100" Style="{StaticResource FlatProgressBar}" Margin="0,0,0,20"/>

                                        <!-- CPU Power -->
                                        <Grid Grid.Row="3" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Processor Power Draw (CPU Power)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray"/>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBlock Text="{Binding CpuPowerNum}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00F5A0"/>
                                                <TextBlock Text=" W" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="Gray"/>
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar Grid.Row="4" Value="{Binding CpuPowerNum}" Minimum="0" Maximum="150" Style="{StaticResource FlatProgressBar}" Margin="0,0,0,20"/>

                                        <!-- RAM Usage -->
                                        <Grid Grid.Row="5" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Physical Memory Load (RAM Usage)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray"/>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBlock Text="{Binding RamUsagePercent}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00F5A0"/>
                                                <TextBlock Text=" %" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="Gray"/>
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar Grid.Row="6" Value="{Binding RamUsagePercent}" Minimum="0" Maximum="100" Style="{StaticResource FlatProgressBar}"/>
                                    </Grid>
                                </Border>

                                <!-- Top-Right: ACTIVE OPTIMIZER CONTEXT -->
                                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="ACTIVE OPTIMIZER CONTEXT" FontFamily="Segoe UI Variable Text" FontSize="11" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>

                                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                            <TextBlock Text="CURRENT GAME TARGET" FontFamily="Segoe UI Variable Text" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                                            <TextBlock Text="Esports Mode: VALORANT" FontFamily="Segoe UI Variable Text" FontSize="16" FontWeight="Bold" Foreground="#00F5A0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="ACTIVE SYSTEM OPTIMIZERS" FontFamily="Segoe UI Variable Text" FontSize="11" Foreground="Gray" Margin="0,0,0,8"/>
                                            
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#00F5A0" CornerRadius="2" Padding="5,2" Grid.Column="0">
                                                    <TextBlock Text="ON" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="Timer Resolution: 0.500 ms (Low latency locked)" FontFamily="Segoe UI Variable Text" FontSize="12.5" Foreground="White" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#00F5A0" CornerRadius="2" Padding="5,2" Grid.Column="0">
                                                    <TextBlock Text="ON" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="CPU Core Parking: Disabled (100% active cores)" FontFamily="Segoe UI Variable Text" FontSize="12.5" Foreground="White" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#00F5A0" CornerRadius="2" Padding="5,2" Grid.Column="0">
                                                    <TextBlock Text="ON" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="GPU &amp; NIC MSI Mode: Enabled (High priority interrupts)" FontFamily="Segoe UI Variable Text" FontSize="12.5" Foreground="White" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Bottom-Left: QUICK TWEAKS -->
                                <Border Grid.Row="1" Grid.Column="0" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="QUICK TWEAKS" FontFamily="Segoe UI Variable Text" FontSize="11" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>
                                        
                                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                            <CheckBox Content="Disable Windows Telemetry &amp; Diagnostics Services" IsChecked="{Binding IsTelemetryDisabled, Mode=TwoWay}" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" Margin="0,0,0,12"/>
                                            <CheckBox Content="Optimize Gaming Ping (Disable Nagle's TCP)" IsChecked="{Binding IsNetworkOptimized, Mode=TwoWay}" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" Margin="0,0,0,12"/>
                                            <CheckBox Content="Auto Purge Standby Memory Cache (Every 5 mins)" IsChecked="{Binding IsRamCleanAuto, Mode=TwoWay}" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" Margin="0,0,0,12"/>
                                            <CheckBox Content="Enable Message Signaled Interrupts (MSI Mode)" IsChecked="{Binding IsMsiEnabled, Mode=TwoWay}" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Bottom-Right: CLEANUP SUMMARY & ONE-CLICK BUTTON -->
                                <Border Grid.Row="1" Grid.Column="1" Padding="30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="CLEANUP SUMMARY" FontFamily="Segoe UI Variable Text" FontSize="11" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>

                                        <!-- Junk -->
                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Estimated System Junk Files" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray"/>
                                            <TextBlock Text="{Binding JunkFilesText}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="1"/>
                                        </Grid>

                                        <!-- Cached Standby -->
                                        <Grid Grid.Row="2" Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Standby Memory Cache Size" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray"/>
                                            <TextBlock Text="{Binding StandbyMemoryText}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="1"/>
                                        </Grid>

                                        <!-- Run Optimize Button -->
                                        <Button Grid.Row="4" Content="RUN OPTIMIZE NOW" Command="{Binding RunOptimizeCommand}" Style="{StaticResource FlatAccentButton}" Height="42" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>

                <!-- 2. HARDWARE TUNING (Flat Sliders/Textboxes) -->
                <ui:NavigationViewItem Content="Hardware Tuning" Icon="DeveloperBoard24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="MANUAL HARDWARE TUNING" FontFamily="Segoe UI Variable Text" FontSize="18" FontWeight="Bold" Foreground="#00F5A0" Margin="0,0,0,35"/>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                                        
                                        <!-- Intel FIVR -->
                                        <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="0,0,0,25" Margin="0,0,0,25">
                                            <StackPanel>
                                                <TextBlock Text="INTEL FIVR VOLTAGE OFFSETS" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>
                                                
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="CPU Core Offset (mV):" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-250" Maximum="0" Value="{Binding IntelCoreOffset, Mode=TwoWay}" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding IntelCoreOffset, StringFormat={}{0} mV}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <Grid.ColumnDefinition Width="200"/>
                                                        <Grid.ColumnDefinition Width="*"/>
                                                        <Grid.ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="CPU Cache Offset (mV):" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-250" Maximum="0" Value="{Binding IntelCacheOffset, Mode=TwoWay}" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding IntelCacheOffset, StringFormat={}{0} mV}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- AMD Section -->
                                        <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="0,0,0,25" Margin="0,0,0,25">
                                            <StackPanel>
                                                <TextBlock Text="AMD RYZEN CURVE OPTIMIZER &amp; TDP" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>
                                                
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions>
                                                        <Grid.ColumnDefinition Width="200"/>
                                                        <Grid.ColumnDefinition Width="*"/>
                                                        <Grid.ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Curve Optimizer Offset:" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <Slider Minimum="-50" Maximum="0" Value="{Binding AmdCoOffset, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AmdCoOffset}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <Grid.ColumnDefinition Width="200"/>
                                                        <Grid.ColumnDefinition Width="150"/>
                                                        <Grid.ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Target TDP Limit (W):" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding AmdTdpText, Mode=TwoWay}" Grid.Column="1" FontFamily="Consolas" FontSize="13" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="28" Background="#1C1C1C" Foreground="White" BorderBrush="#2D2D2D" BorderThickness="1"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Button Content="Apply Hardware Settings" Command="{Binding ApplyHardwareCommand}" Style="{StaticResource FlatAccentButton}" Width="230" Height="38" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>

                <!-- 3. OPTIMIZE & BENCHMARK (Flat Side-by-Side Table) -->
                <ui:NavigationViewItem Content="Optimize &amp; Benchmark" Icon="PlayRate24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="PERFORMANCE BENCHMARK &amp; COMPARISON" FontFamily="Segoe UI Variable Text" FontSize="18" FontWeight="Bold" Foreground="#00F5A0" Margin="0,0,0,35"/>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Controls -->
                                    <Grid Grid.Column="0" Margin="0,0,25,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="AUTOMATED BENCHMARK SEQUENCE" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,15"/>
                                            <TextBlock Text="The benchmark engine will measure your system's baseline metrics (Stock), apply hardware configurations and latency tweaks, and measure them again under identical compute loads to compute real-time performance gains." TextWrapping="Wrap" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray" Margin="0,0,0,25" LineHeight="18"/>
                                            
                                            <!-- Progress Status -->
                                            <Border BorderBrush="#2D2D2D" BorderThickness="1" Padding="15" Margin="0,0,0,15" Visibility="{Binding ProgressCardVisibility, FallbackValue=Collapsed}">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <ProgressBar IsIndeterminate="True" Height="4" Foreground="#00F5A0" Background="#2D2D2D" BorderThickness="0" Width="220" Margin="0,0,0,12"/>
                                                    <TextBlock Text="{Binding BenchmarkStatusText}" TextWrapping="Wrap" TextAlignment="Center" FontFamily="Segoe UI Variable Text" FontSize="12" Foreground="#00F5A0" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <Button Grid.Row="1" Content="START PERFORMANCE RUN" Command="{Binding RunAutoOptBenchmarkCommand}" Style="{StaticResource FlatAccentButton}" Height="40" HorizontalAlignment="Stretch"/>
                                    </Grid>

                                    <!-- Splitter Line -->
                                    <Border Grid.Column="1" Background="#2D2D2D" Width="1" VerticalAlignment="Stretch"/>
                                    
                                    <!-- Results Side-by-Side Table -->
                                    <Grid Grid.Column="2" Margin="25,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="COMPARATIVE METRICS BOARD" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,20"/>
                                        
                                        <Grid Grid.Row="1" VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Headers -->
                                            <TextBlock Text="Performance Metric" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Grid.Row="0" Grid.Column="0" Margin="0,0,0,15"/>
                                            <TextBlock Text="Stock System" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" TextAlignment="Center"/>
                                            <TextBlock Text="vOptimizer Tuning" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Grid.Row="0" Grid.Column="2" Margin="0,0,0,15" TextAlignment="Center"/>
                                            <TextBlock Text="Improvement" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Grid.Row="0" Grid.Column="3" Margin="0,0,0,15" TextAlignment="Center"/>

                                            <!-- Score -->
                                            <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Grid.Row="1" Grid.ColumnSpan="4" Padding="0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Compute Score (GOPs)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StockScoreText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OptScoreText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DiffScoreText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Peak Temp -->
                                            <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Grid.Row="2" Grid.ColumnSpan="4" Padding="0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Peak CPU Temp (°C)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StockTempText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OptTempText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DiffTempText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- Avg Power -->
                                            <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Grid.Row="3" Grid.ColumnSpan="4" Padding="0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Average Power Draw (W)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StockPowerText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OptPowerText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DiffPowerText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- Efficiency -->
                                            <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,0" Grid.Row="4" Grid.ColumnSpan="4" Padding="0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Compute Efficiency (GOPs/W)" FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StockEfficiencyText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" Grid.Column="1" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OptEfficiencyText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="2" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DiffEfficiencyText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="#00F5A0" Grid.Column="3" TextAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>

                <!-- 4. SYSTEM CONFIG (Eco Mode & Scheduler Setup) -->
                <ui:NavigationViewItem Content="Settings" Icon="Settings24">
                    <ui:NavigationViewItem.ContentTemplate>
                        <DataTemplate>
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="vOPTIMIZER SYSTEM SETTINGS" FontFamily="Segoe UI Variable Text" FontSize="18" FontWeight="Bold" Foreground="#00F5A0" Margin="0,0,0,35"/>
                                
                                <StackPanel Grid.Row="1" MaxWidth="700" HorizontalAlignment="Left">
                                    
                                    <!-- Eco Mode -->
                                    <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="0,0,0,25" Margin="0,0,0,25">
                                        <StackPanel>
                                            <CheckBox Content="Eco Mode (Disable UI Effects)" IsChecked="{Binding IsEcoMode, Mode=TwoWay}" FontFamily="Segoe UI Variable Text" FontSize="13.5" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                            <TextBlock Text="Disables Windows 11 Mica backdrop blurring effects and switches the app window background to a flat solid gray (#141414) to eliminate GPU overhead, saving rendering resources for active gaming." TextWrapping="Wrap" FontFamily="Segoe UI Variable Text" FontSize="12.5" Foreground="Gray" Margin="25,0,0,0" LineHeight="17"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Task Scheduler Auto Start -->
                                    <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="0,0,0,25" Margin="0,0,0,25">
                                        <StackPanel>
                                            <CheckBox Content="Autostart with Windows Login (Bypass UAC)" IsChecked="False" IsEnabled="False" FontFamily="Segoe UI Variable Text" FontSize="13.5" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                                            <TextBlock Text="Registers a task in the Windows Task Scheduler to automatically launch vOptimizer with Administrator privileges at login, avoiding standard UAC prompts." TextWrapping="Wrap" FontFamily="Segoe UI Variable Text" FontSize="12.5" Foreground="Gray" Margin="25,0,0,0" LineHeight="17"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Driver Info Status -->
                                    <Border BorderBrush="#2D2D2D" BorderThickness="0,0,0,0" Padding="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="SYSTEM KERNEL DRIVER STATUS" FontFamily="Segoe UI Variable Text" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,12"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#00F5A0" CornerRadius="2" Padding="6,3" HorizontalAlignment="Left" Grid.Column="0">
                                                    <TextBlock Text="ACTIVE" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                                                </Border>
                                                <TextBlock Text="The WinRing0x64 kernel hardware driver is successfully loaded and operating at Ring 0 privileges." FontFamily="Segoe UI Variable Text" FontSize="13" Foreground="LightGray" Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ui:NavigationViewItem.ContentTemplate>
                </ui:NavigationViewItem>
                
            </ui:NavigationView.MenuItems>

            <ui:Frame x:Name="RootFrame" />

        </ui:NavigationView>
    </Grid>
</ui:UiWindow>
